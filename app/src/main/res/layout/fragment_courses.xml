<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="30dp"
    tools:context=".ui.courses.CoursesFragment">

    <LinearLayout
        android:id="@+id/addCourse"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/currentCourses"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_add_paper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_paper"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_paper_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paper_code" />

        <EditText
            android:id="@+id/editText_paper_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:ems="10"
            android:inputType="text"
            android:minHeight="48dp"
            android:text="@string/paper_code_hint"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_occ_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:text="@string/occurrence_code"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editText_occ_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autofillHints="@string/occurrence_code_hint"
            android:ems="10"
            android:inputType="text"
            android:minHeight="48dp"
            android:text="@string/occurrence_code_hint"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:text="@string/location"
            android:textSize="14sp" />

        <RadioGroup
            android:id="@+id/radioGroup_location"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radio_location_ham"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radio_button_ham"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/radio_location_tga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radio_button_tga"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/radio_location_net"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radio_button_net"
                android:textSize="14sp" />

        </RadioGroup>

        <Button
            android:id="@+id/button_search_paper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:onClick="processCourseOutline"
            android:text="@string/search_button"
            android:textAlignment="center"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/currentCourses"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/staffList"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addCourse">

        <TextView
            android:id="@+id/text_current_papers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/current_paper" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/paperRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/staffList"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/currentCourses"></LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>