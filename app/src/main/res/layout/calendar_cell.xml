<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="3dp"
        android:background="@drawable/calendar_cell_bg"
        android:minHeight="80dp">

    <TextView
        android:id="@+id/text_day_number"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="#212121"/>

    <TextView android:id="@+id/chip_event_1"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="2dp"
        android:paddingStart="3dp"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/calendar_chip_bg"
        android:visibility="gone"
        tools:ignore="RtlSymmetry" />

    <TextView android:id="@+id/chip_event_2"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="2dp"
        android:paddingStart="3dp"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/calendar_chip_bg"
        android:visibility="gone"
        tools:ignore="RtlSymmetry" />

    <TextView android:id="@+id/chip_event_3"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="2dp"
        android:paddingStart="3dp"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@drawable/calendar_chip_bg"
        android:visibility="gone"
        tools:ignore="RtlSymmetry" />

    <TextView android:id="@+id/text_overflow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#757575"
        android:gravity="end"
        android:visibility="gone" />

</LinearLayout>


